Notebook[{
Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"xMin", "=", 
     RowBox[{"-", "6"}]}], ";", 
    RowBox[{"xMax", "=", "6"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"n", "=", "101"}], ";"}], "                  ", "\n", 
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{"xMin", ",", "xMax", ",", 
       RowBox[{"n", "-", "1"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dx", "=", 
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "-", 
      RowBox[{"x", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"V", "=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "^", "2"}], ")"}], "/", "2."}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"V1", "=", 
     RowBox[{
      RowBox[{"DiagonalMatrix", "[", 
       RowBox[{"(", 
        RowBox[{"x", "^", "4"}], ")"}], "]"}], "/", "40."}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"main", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{
       RowBox[{"-", "2."}], ",", "n"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"off", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"1.", ",", 
       RowBox[{"n", "-", "1"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"D2", "=", 
     RowBox[{
      RowBox[{"SparseArray", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Band", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", "1"}], "}"}], "]"}], "->", "main"}], ",", 
          RowBox[{
           RowBox[{"Band", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", "2"}], "}"}], "]"}], "->", "off"}], ",", 
          RowBox[{
           RowBox[{"Band", "[", 
            RowBox[{"{", 
             RowBox[{"2", ",", "1"}], "}"}], "]"}], "->", "off"}]}], "}"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "n"}], "}"}]}], "]"}], "/", 
      RowBox[{"dx", "^", "2"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"1", "/", "2."}], ")"}]}], " ", "D2"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"H", "=", 
     RowBox[{"T", "+", "V", "+", "V1"}]}], ";"}], "\[IndentingNewLine]", "\n",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"vals", ",", "vecs"}], "}"}], "=", 
     RowBox[{"Eigensystem", "[", "H", "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]"}]}]], "Input",
